{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": { "@/*": ["../src/*"] }
  },
  "include": ["src/**/*.ts", "../src/lib/types.ts"]
}
